# ============================================
# CONFIGURACIÓN - NIOVAL Sistema de Llamadas
# ============================================
# Copia este archivo a .env y completa con tus credenciales reales

# ===== LLM Provider (FIX 819) =====
# "openai" = GPT-4o-mini (default)
# "anthropic" = Claude Haiku 4.5 (recomendado para mejor razonamiento)
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
# Para Claude: LLM_PROVIDER=anthropic, LLM_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_API_KEY=sk-ant-xxxxx

# ===== OpenAI =====
# REQUERIDO para:
# - GPT-4o-mini (agente conversacional, si LLM_PROVIDER=openai)
# - Whisper API (fallback de transcripcion - FIX 60)
OPENAI_API_KEY=sk-proj-xxxxx

# ===== Deepgram (FIX 212) =====
# RECOMENDADO para transcripción en tiempo real
# - Precisión: 90%+ en español
# - Latencia: <100ms (vs 2-5s de Whisper)
# - Costo: $0.0043/min (más barato que Whisper y Twilio)
# Obtener API Key: https://console.deepgram.com/
DEEPGRAM_API_KEY=xxxxxxxxxxxxxxxx
USE_DEEPGRAM=true

# ===== GitHub Models (alternativa gratis para testing) =====
USE_GITHUB_MODELS=true
GITHUB_TOKEN=ghp_xxxxx

# ===== ElevenLabs =====
ELEVENLABS_API_KEY=sk_xxxxx
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB
ELEVENLABS_AGENT_ID=agent_xxxxx

# ===== Twilio =====
TWILIO_ACCOUNT_SID=ACxxxxx
TWILIO_AUTH_TOKEN=xxxxx
TWILIO_PHONE_NUMBER=+52xxxxx

# ===== Google Sheets =====
GOOGLE_CREDENTIALS_FILE=credentials.json
SPREADSHEET_NAME=NIOVAL - Sistema de Llamadas

# ===== WhatsApp Validator =====
# Opciones: "formato" (gratis), "twilio" (pago), "evolution" (recomendado)
WHATSAPP_VALIDATOR_METHOD=formato

# Evolution API (solo si WHATSAPP_VALIDATOR_METHOD=evolution)
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=xxxxx

# ===== Configuración de Llamadas Automáticas =====
LLAMADAS_POR_DIA=100
DELAY_LLAMADAS_SEG=60
HORARIO_INICIO=09:00
HORARIO_FIN=17:00

# ===== Webhook URL (para Twilio) =====
# URL pública de tu servidor Flask (usar ngrok para desarrollo)
WEBHOOK_URL=https://tu-servidor.com
